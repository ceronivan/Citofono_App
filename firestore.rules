rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios — cada uno lee/escribe su propio doc
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Códigos de invitación — lectura pública (necesaria para validar el código
    // antes de crear la cuenta). Escritura solo autenticados.
    match /invites/{code} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Documento del conjunto (nombre, torres, amenidades)
    match /complexes/{complexId} {
      allow read, write: if request.auth != null;
    }

    // Datos del conjunto — cualquier usuario autenticado puede leer/escribir
    // (los permisos finos por rol se aplican desde el frontend con los guards)
    match /complexes/{complexId}/{collection}/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
