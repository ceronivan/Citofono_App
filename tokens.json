{
  "$comment": "Fuente única de design tokens de PortalResidencial. Editar AQUÍ y correr `npm run tokens` para regenerar src/assets/styles/variables.css (Vue) y mobile/src/theme.ts (React Native).",
  "color": {
    "brand": {
      "primary": "#4F35E8",
      "primaryLight": "#7B64F0",
      "primarySoft": "#EDE9FF",
      "primary10": "rgba(79, 53, 232, 0.08)"
    },
    "state": {
      "success": "#22C55E",
      "successSoft": "#DCFCE7",
      "warning": "#F59E0B",
      "warningSoft": "#FEF3C7",
      "error": "#EF4444",
      "errorSoft": "#FEE2E2",
      "info": "#3B82F6",
      "infoSoft": "#DBEAFE"
    },
    "surface": {
      "bg": "#F8F8FC",
      "surface": "#FFFFFF",
      "surface2": "#F2F2F7",
      "border": "#E5E5EA",
      "borderLight": "#F2F2F7"
    },
    "text": {
      "$comment": "Secundario/terciario oscurecidos para contraste WCAG AA en texto pequeño (unificado desde la versión RN).",
      "primary": "#09090B",
      "secondary": "#5D5D66",
      "tertiary": "#7E7E87",
      "disabled": "#A8A8B0"
    },
    "role": {
      "resident": "#4F35E8",
      "admin": "#0EA5E9",
      "guard": "#10B981"
    }
  },
  "font": {
    "family": "Inter",
    "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "extrabold": 800 },
    "size": {
      "$comment": "Piso accesible de 12px en toda la app.",
      "xs": 12,
      "sm": 13,
      "base": 15,
      "lg": 17,
      "xl": 20,
      "2xl": 24,
      "3xl": 30
    }
  },
  "spacing": { "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24, "8": 32, "10": 40 },
  "radius": { "sm": 8, "md": 12, "lg": 18, "xl": 24, "2xl": 32, "full": 9999 },
  "shadow": {
    "xs": {
      "css": "0 1px 2px rgba(0, 0, 0, 0.04)",
      "native": { "opacity": 0.04, "radius": 2, "offsetY": 1, "elevation": 1 }
    },
    "sm": {
      "css": "0 2px 8px rgba(0, 0, 0, 0.06), 0 0 0 1px rgba(0, 0, 0, 0.03)",
      "native": { "opacity": 0.06, "radius": 8, "offsetY": 2, "elevation": 2 }
    },
    "md": {
      "css": "0 4px 16px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(0, 0, 0, 0.03)",
      "native": { "opacity": 0.08, "radius": 16, "offsetY": 4, "elevation": 4 }
    },
    "lg": {
      "css": "0 8px 32px rgba(0, 0, 0, 0.10), 0 0 0 1px rgba(0, 0, 0, 0.03)",
      "native": { "opacity": 0.1, "radius": 24, "offsetY": 8, "elevation": 6 }
    }
  },
  "nav": { "height": 84 },
  "roles": {
    "resident": { "label": "Residente", "icon": "account-outline" },
    "admin": { "label": "Admin", "icon": "shield-crown-outline" },
    "guard": { "label": "Portería", "icon": "security" }
  }
}
